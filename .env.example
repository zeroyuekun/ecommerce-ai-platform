# Copy to .env.local for local dev. Never commit real secrets.
#
# --- Sanity (required) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_WRITE_TOKEN=

# --- Clerk (required) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Stripe (required) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Vercel AI Gateway (required for /api/chat) ---
AI_GATEWAY_API_KEY=

# --- Site URL (optional; used in OG metadata + absolute links) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Upstash rate-limit backend (optional) ---
# When both are set, the chat rate limiter uses durable sliding-window
# Redis state; otherwise it falls back to in-memory (per-container).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- PostHog product analytics (optional) ---
# When `NEXT_PUBLIC_POSTHOG_KEY` is set, the client-side analytics
# provider initialises on mount. Server-side event capture uses
# `POSTHOG_API_KEY` (falls back to the NEXT_PUBLIC_ key).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Set NEXT_PUBLIC_POSTHOG_DEBUG=1 to capture events from dev as well.
NEXT_PUBLIC_POSTHOG_DEBUG=
POSTHOG_API_KEY=
POSTHOG_HOST=
