# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sanity generated types — regenerate via `pnpm typegen`
sanity.types.ts
schema.json

# Search eval ephemeral results (keep baseline.json tracked)
tests/search-eval/results-*.json
tests/search-eval/latest.json

# k6 ephemeral result files (commit canonical runs explicitly by adding -f)
tests/load/results/*.json
!tests/load/results/canonical-*.json
